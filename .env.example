# AI Skin Health Monitor — copy to .env

# Backend (Member 4)
POSTGRES_URL=postgresql+asyncpg://user:pass@localhost:5432/skin_monitor
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-32-byte-random-string-for-demo

# Set to 1 to use mock analysis when services are down
MOCK_ANALYSE=0

# Service URLs (used by backend when running locally)
IMAGE_PROCESSOR_URL=http://localhost:8001
AI_INFERENCE_URL=http://localhost:8002

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8000
